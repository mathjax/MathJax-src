    <munderover data-latex="\\sum_{i=1}^N">
      <mo data-latex="\\sum">&#x2211;</mo>
      <mrow data-mjx-texclass="ORD" data-latex="{i=1}">
        <mi data-latex="i">i</mi>
        <mo data-latex="=">=</mo>
