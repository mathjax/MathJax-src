    <mi data-latex="X">X</mi>
    <mrow data-mjx-texclass="ORD" data-latex="{}">
      <mrow data-mjx-texclass="ORD">
        <mrow data-mjx-texclass="OPEN" data-latex="\\bigl [">
          <mo minsize="1.2em" maxsize="1.2em">[</mo>
