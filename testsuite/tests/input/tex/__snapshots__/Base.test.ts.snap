          <mi data-latex="i">i</mi>
        </msub>
        <mo data-latex="-">&#x2212;</mo>
        <mi data-latex="\\mu">&#x3BC;</mi>
        <mo data-latex=")" stretchy="false">)</mo>
      </mrow>
      <mn data-latex="2">2</mn>
    </msup>
  </msqrt>
</math>"
`;

